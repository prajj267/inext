# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Neon PostgreSQL (get these from neon.tech dashboard) ──────
# Use the pooled connection URL for the app (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true"

# Use the direct (non-pooled) URL for migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The public URL of your deployed site (no trailing slash)
NEXTAUTH_URL="https://your-site.vercel.app"

# ── Admin account ─────────────────────────────────────────────
# Used only when seeding the database the first time
ADMIN_PASSWORD="choose-a-strong-password"

# ── Vercel Blob (for photo uploads) ──────────────────────────
# Get this from: Vercel Dashboard → your project → Storage → Blob → .env.local
BLOB_READ_WRITE_TOKEN="your-blob-token-here"
